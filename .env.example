# --- Bajaj DMS credentials (REQUIRED) ---
# Your agency / employee ADID (will be uppercased automatically)
BAJAJ_USERNAME=A14796069
# The matching password
BAJAJ_PASSWORD=changeme

# --- Django ---
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DJANGO_DEBUG=False
# Use * to allow any Host (dev/LAN). In production set explicit hostnames.
DJANGO_ALLOWED_HOSTS=*
# Comma-separated full origins (scheme + host + port) for CSRF-checked POSTs
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# --- Bajaj client (long batch jobs) ---
BAJAJ_SESSION_RENEW_BUFFER_SECONDS=180
BAJAJ_SOA_FETCH_MAX_RETRIES=8

# --- Batch report (optional) ---
SOA_BATCH_DELAY_SECONDS=0.35
SOA_BATCH_MAX_LOANS=20000
# Parallel SOA HTTP threads (1–32). Lower if portal returns session conflicts.
SOA_BATCH_FETCH_WORKERS=10
SOA_BATCH_MAX_UPLOAD_BYTES=10485760
SOA_BATCH_JOB_RETENTION_DAYS=7
